load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
load("@ecos-bazel//rules:python_packaging.bzl", "cpp_runtime_bundle")
load("@pkg_config_path//:defs.bzl", "PKG_CONFIG_PATH")

package(default_visibility = ["//visibility:public"])

cmake(
    name = "ecc_py_cmake",
    lib_source = "@ecc_tools_src//:all_sources",
    cache_entries = {
        "BUILD_ECOS": "ON",
        "BUILD_PYTHON": "ON",
        "BUILD_STATIC_LIB": "OFF",
        "CMAKE_BUILD_TYPE": "Release",
        "Python3_EXECUTABLE": "$$EXT_BUILD_ROOT/$(execpath @python_3_11//:python3)",
        "Python3_ROOT_DIR": "$$(dirname $$(dirname $$EXT_BUILD_ROOT/$(execpath @python_3_11//:python3)))",
        "Python3_FIND_STRATEGY": "LOCATION",
        # pybind11's FindPythonLibsNew uses legacy FindPythonInterp which only recognizes PYTHON_EXECUTABLE.
        "PYTHON_EXECUTABLE": "$$EXT_BUILD_ROOT/$(execpath @python_3_11//:python3)",
    },
    build_data = [
        "@python_3_11//:python3",
        "@python_3_11//:python_headers",
        "@python_3_11//:libpython",
    ],
    targets = ["ecc_py"],
    install = False,
    postfix_script = """
        mkdir -p $$INSTALLDIR/lib
        ECC_PY_ABI=$$($$EXT_BUILD_ROOT/$(execpath @python_3_11//:python3) -c "import sysconfig; print(sysconfig.get_config_var('EXT_SUFFIX'))")
        find -L $$EXT_BUILD_ROOT/external -name "ecc_py*$${ECC_PY_ABI}" -exec cp -f {} $$INSTALLDIR/lib/ \\;
        find . -name '*.so' -exec cp -f {} $$INSTALLDIR/lib/ \\;
        ls $$INSTALLDIR/lib/ecc_py* >/dev/null 2>&1 || { echo "ERROR: ecc_py .so not found"; exit 1; }
    """,
    out_headers_only = True,
    env = {"PKG_CONFIG_PATH": PKG_CONFIG_PATH},
    generate_args = ["-GNinja"],
    out_data_dirs = ["lib"],
)

cmake(
    name = "dreamplace_cmake",
    lib_source = "@dreamplace_src//:all_sources",
    cache_entries = {
        "CMAKE_BUILD_TYPE": "Release",
        # Must match torch's _GLIBCXX_USE_CXX11_ABI (pip torch uses 1).
        "CMAKE_CXX_ABI": "1",
        "PYTHON_EXECUTABLE": "$$EXT_BUILD_ROOT/$(execpath @python_3_11//:python3)",
        "TORCH_INSTALL_PREFIX": "$$EXT_BUILD_ROOT/external/rules_python++pip+pypi_311_torch/site-packages/torch",
        "TORCH_ENABLE_CUDA": "0",
        "TORCH_VERSION": "2.10.0",
    },
    build_data = [
        "@python_3_11//:python3",
        "@python_3_11//:python_headers",
        "@python_3_11//:libpython",
        "@pypi//torch",
    ],
    install = True,
    out_headers_only = True,
    postfix_script = """
        echo "DreamPlace: build and install completed"
    """,
    env = {
        "PKG_CONFIG_PATH": PKG_CONFIG_PATH,
        "PYTHONPATH": "$$EXT_BUILD_ROOT/external/rules_python++pip+pypi_311_torch/site-packages",
    },
    generate_args = ["-GNinja"],
    out_data_dirs = ["dreamplace"],
)

cpp_runtime_bundle(
    name = "ecc_bundle",
    cmake_target = ":ecc_py_cmake",
    dest_bin_dir = "chipcompiler/tools/ecc/bin",
    dest_lib_dir = "chipcompiler/tools/ecc/bin/lib",
    so_pattern = "ecc_py*.so",
    autopatch_script = "@ecos-bazel//tools:autopatch_runtime",
    auto_patchelf_bin = "@ecos-bazel//tools/auto-patchelf:auto_patchelf",
    patchelf = "@patchelf//:bin/patchelf",
)
